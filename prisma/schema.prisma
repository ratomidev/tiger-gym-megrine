generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  role      Role 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  OWNER 
  STAFF
}

model Subscription {
  id                   String   @id @default(cuid())
  adherentId           String   @unique
  startDate            DateTime
  endDate              DateTime
  plan                 String
  price                Decimal  @db.Decimal(10, 3)
  remaining            Decimal  @default(0) @db.Decimal(10, 3)  // New field for tracking unpaid amount
  status               String   @default("actif")
  hasCardioMusculation Boolean  @default(false)
  hasCours             Boolean  @default(false)
  adherent             Adherent @relation(fields: [adherentId], references: [id])
}

model Adherent {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String        @unique
  phone        String
  birthDate    DateTime
  Address      String
  createdAt    DateTime      @default(now())
  isValidated  Boolean       @default(false)
  photoUrl     String?
  sexe         String
  subscription Subscription?
}
